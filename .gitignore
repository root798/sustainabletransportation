# ---- Results MC RUN dumps (multi-MB per run; regenerable) ----
# Only the small `*_quantiles.csv` files are tracked (see whitelist below).
/results/*_mc_runs.csv
/results/*_metrics.csv
/results/*_extras.csv
/results/*_metadata.json
/results_notebook/

# ---- Stray figures / PDFs at root ----
/cav_sti_combined.png
/clear_ats_uncertainty_figure_v30.drawio.pdf
/sti_1yr_total_energy_consumption.pdf
/sti_1yr_total_energy_consumption.png

# ---- Self-contained release mirrors (root tree is the canonical deploy) ----
/clean_release_v10/
/clean_release_v11/

# =====================================================================
# Whitelist: things explicitly tracked for the v11 cloud deploy.
# Anything listed above with a leading `/` is overridden here with `!`.
# =====================================================================
!/footprint_model.py
!/configs/
!/configs/**
!/scenarios/
!/scenarios/**
!/v4_streamlit_app/
!/v4_streamlit_app/**
!/v11_streamlit_app/
!/v11_streamlit_app/**
!/src/
!/src/clearats/
!/src/clearats/**

# Quantile CSVs (small, needed for offline fallback in the Scenario Explorer).
!/results/
!/results/*_quantiles.csv
!/results/*_quantiles_metadata.json

# =====================================================================
# Re-apply ignores INSIDE the whitelisted trees (whitelists are greedy
# and otherwise pull in caches, IDE junk, and bulky doc artefacts).
# =====================================================================
**/__pycache__/
**/*.py[cod]
**/.DS_Store
v11_streamlit_app/USER GUIDE/
v11_streamlit_app/assets/*.psd
v11_streamlit_app/figs/
v11_streamlit_app/scripts/__pycache__/
v11_streamlit_app/analysis/
v4_streamlit_app/*.md
v4_streamlit_app/*.csv
